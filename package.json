{
  "name": "hostel_managemet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "cd backend && uvicorn main:app --host 0.0.0.0 --port ${PORT:-10000}",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "frontend": "vite",
    "backend": "cd backend && uvicorn main:app --host 0.0.0.0 --port 3000 --reload",
    "build": "vite build && cd backend && pip3 install -r requirements.txt || pip install -r requirements.txt && python3 init_db.py || python init_db.py",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "vite": "^5.4.10"
  }
}
